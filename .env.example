# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI="example_user:example_password@localhost:27017/example_db?authSource=admin"

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=8f5db9b1a5e12e87c0d292211910a34b223d49f6916a8b7c7b8f2d54e4c3a2f1
JWT_REFRESH_SECRET=b3a1d9c745f8e6b19a1c62f2d9c4b7e810f3a6b2c45e8d9f1a2b3c4d5e6f7a8b

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Client (CORS) ─────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ── Cloudinary (media uploads — optional) ────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── AI / NLP Matching microservice (optional) ─────────────────────────────────
NLP_SERVICE_URL=http://localhost:8000
